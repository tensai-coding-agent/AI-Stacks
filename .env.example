# AI Stacks Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Node.js Environment
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aistacks
POSTGRES_PASSWORD=aistacks_dev
POSTGRES_DB=aistacks
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# =============================================================================
# MinIO / S3 Configuration
# =============================================================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=aistacks
S3_ENDPOINT=http://${MINIO_ENDPOINT}:${MINIO_PORT}
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# =============================================================================
# Qdrant Vector Database
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://${QDRANT_HOST}:${QDRANT_PORT}
QDRANT_API_KEY=

# =============================================================================
# AI / LLM Configuration
# =============================================================================
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Other AI providers
HUGGINGFACE_TOKEN=your_huggingface_token_here
COHERE_API_KEY=your_cohere_api_key_here

# =============================================================================
# Authentication (for web projects)
# =============================================================================
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
SESSION_SECRET=your_session_secret_here

# =============================================================================
# Monitoring & Observability
# =============================================================================
# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_AI_FEATURES=true
ENABLE_DEBUG_LOGGING=true

Co-Authored-By: Paperclip <noreply@paperclip.ing>
