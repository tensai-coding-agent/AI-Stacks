# Graph Node Environment Configuration

# Ethereum RPC Endpoints (Required)
# Get API keys from Alchemy (https://dashboard.alchemy.com/) or Infura
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Optimism
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY
OPTIMISM_WS_URL=wss://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Arbitrum
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ARBITRUM_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Base
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# PostgreSQL Configuration
GRAPH_POSTGRES_USER=graphnode
GRAPH_POSTGRES_PASSWORD=graphnode
GRAPH_POSTGRES_DB=graphnode
GRAPH_POSTGRES_PORT=5433

# IPFS Configuration
IPFS_API_PORT=5001
IPFS_GATEWAY_PORT=8081
IPFS_SWARM_PORT=4001
# Optional: Set for private IPFS swarm
# IPFS_SWARM_KEY=/key/swarm/psk/1.0.0/\n/base16/...
IPFS_PROFILE=server

# Graph Node Configuration
GRAPH_NODE_ADMIN_PORT=8020
GRAPH_NODE_RPC_PORT=8030
GRAPH_NODE_METRICS_PORT=8040
GRAPH_NODE_QUERY_PORT=8000

# Logging and Performance
GRAPH_LOG_LEVEL=info
GRAPH_QUERY_TIMEOUT=30
GRAPH_MAX_COMPLEXITY=1000000
GRAPH_MAX_DEPTH=32
GRAPH_DB_TIMEOUT=5000
GRAPH_DB_POOL_SIZE=10
GRAPH_NODE_ID=framesight-node-0

# Subgraph Deployment
SUBGRAPH_VERSION_LABEL=v1.0.0
