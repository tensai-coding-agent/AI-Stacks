# FrameSight Indexer Environment Variables

# Database
INDEXER_DATABASE_URL=postgres://user:password@localhost:5432/framesight

# RPC Endpoints (replace with your actual endpoints)
INDEXER_CHAINS_0_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
INDEXER_CHAINS_0_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

INDEXER_CHAINS_1_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
INDEXER_CHAINS_1_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

INDEXER_CHAINS_2_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
INDEXER_CHAINS_2_WS_URL=wss://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

INDEXER_CHAINS_3_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
INDEXER_CHAINS_3_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

INDEXER_CHAINS_4_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
INDEXER_CHAINS_4_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Indexing mode: realtime, backfill, hybrid
INDEXER_MODE=hybrid

# API
INDEXER_API_ENABLED=true
INDEXER_API_BIND_ADDRESS=0.0.0.0:8080

# Logging
RUST_LOG=info,framesight_indexer=debug

# Optional: Kafka
# INDEXER_KAFKA_BROKERS=localhost:9092
# INDEXER_KAFKA_TOPIC=framesight-events
