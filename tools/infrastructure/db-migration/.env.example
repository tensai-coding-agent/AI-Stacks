# FrameSight Database Migration Environment

# SQLite source database
SQLITE_PATH=./framesight.db

# TimescaleDB target database
PG_HOST=localhost
PG_PORT=5432
PG_DB=framesight
PG_USER=framesight
PG_PASSWORD=framesight_dev

# Optional services
GRAFANA_PASSWORD=admin
PGADMIN_EMAIL=admin@tensai.local
PGADMIN_PASSWORD=admin

# API Keys for data sources (replace with actual keys)
ALCHEMY_KEY=your_alchemy_key_here
